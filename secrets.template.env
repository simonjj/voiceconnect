# VoiceConnect — example secrets/parameters for deploy.ps1
#
# Copy this file to `secrets.env` (gitignored) and source it in your shell
# before running ./infra/deploy.ps1, or pass values explicitly on the
# command line.

# Auth token the client sends to the server (also used to register agents).
AUTH_TOKEN=dev-token

# GitHub token Copilot CLI uses inside each sandbox. If unset, deploy.ps1
# falls back to `gh auth token`.
GITHUB_TOKEN=

# Subscription / ACR (only if different from defaults).
SUBSCRIPTION_ID=
ACR_NAME=simon
ACR_RESOURCE_GROUP=simonj

# Image tag to deploy. The captured demo snapshot uses `demo-2026-05-28`.
IMAGE_TAG=demo-2026-05-28

# Snapshot names — leave blank to bootstrap fresh sandboxes from scratch.
ARIA_SNAPSHOT=aria-demo-2026-05-28
NOVA_SNAPSHOT=nova-demo-2026-05-28
