{
  "name": "connect",
  "productName": "VoiceConnect",
  "version": "5.0.3",
  "description": "Connect - collaboration platform",
  "main": "main/index.js",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "posttest": "eslint .",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rimraf renderer/dist",
    "start": "echo $(env)",
    "start:watch": "echo 'start is deprecated, use yarn watch' && exit 1",
    "watch": "yarn run clean && webpack serve --config renderer/webpack/development.js --progress",
    "build": "yarn run clean && NODE_ENV=production webpack --config renderer/webpack/production.js",
    "build:dev": "yarn run clean && NODE_ENV=development webpack --config renderer/webpack/production.js",
    "pack": "electron-builder",
    "pack:dir-only": "electron-builder --dir",
    "electron": "NODE_ENV=development nodemon --watch main --exec ./node_modules/.bin/electron\\ .",
    "debug:electron": "yarn electron -- --inspect=0.0.0.0:5858",
    "debug:electronbrk": "yarn electron -- --inspect-brk=0.0.0.0:5858",
    "pre-commit": "pretty-quick --staged;",
    "clear:config": "node main/utils/clearConfig.js",
    "clear:configdir": "node main/utils/clearConfig.js --rf"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/touchto/connect.git"
  },
  "keywords": [
    "video",
    "node",
    "react",
    "WebRTC"
  ],
  "author": "VoiceConnect, Inc. <support@getteamconnect.app>",
  "license": "Unlicense",
  "homepage": "https://bitbucket.org/touchto/connect#readme",
  "browserslist": [
    "chrome>60"
  ],
  "build": {
    "appId": "app.getteamconnect.connect",
    "afterSign": "scripts/notarize.js",
    "productName": "VoiceConnect",
    "electronDownload": {
      "version": "12.0.2"
    },
    "protocols": [
      {
        "name": "connect",
        "schemes": [
          "connect"
        ]
      }
    ],
    "files": [
      "main",
      "!main/config/local-*.*",
      "shared",
      "renderer/dist",
      "renderer/preload",
      "renderer/assets"
    ],
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "tar.gz"
      ]
    },
    "win": {
      "publisherName": [
        "VoiceConnect, Inc."
      ]
    },
    "publish": {
      "provider": "s3",
      "bucket": "connect-archive",
      "autoUpdate": true
    }
  },
  "dependencies": {
    "appdata-path": "^1.0.0",
    "config": "^3.3.6",
    "debug": "^4.3.1",
    "electron-context-menu": "^2.5.0",
    "electron-updater": "^4.3.8",
    "joi": "^17.4.0",
    "jsonwebtoken": "^8.5.1",
    "jwt-decode": "^3.1.2",
    "keytar": "^7.7.0",
    "node-localstorage": "^2.2.1",
    "rimraf": "^3.0.2",
    "superagent": "^6.1.0",
    "universal-analytics": "^0.4.23",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.13.12",
    "@babel/preset-react": "^7.13.13",
    "@babel/runtime": "^7.13.10",
    "@hot-loader/react-dom": "^17.0.1",
    "@loadable/babel-plugin": "^5.13.2",
    "@loadable/component": "^5.14.1",
    "@material-ui/core": "^4.11.3",
    "@material-ui/lab": "^4.0.0-alpha.60",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^11.2.6",
    "@touchto/dev-config": "^1.0.4",
    "@touchto/eslint-config": "^1.2.4",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^8.2.2",
    "css-loader": "^5.2.0",
    "cssnano": "^4.1.11",
    "dotenv": "^8.2.0",
    "electron": "16.0.7",
    "electron-builder": "22.11.11",
    "electron-notarize": "^1.0.0",
    "eslint": "6.8.0",
    "eslint-config-react-app": "^6.0.0",
    "eslint-plugin-flowtype": "^5.6.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.23.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "file-loader": "^6.2.0",
    "html-loader": "^2.1.2",
    "html-webpack-plugin": "^5.3.1",
    "husky": "4.3.8",
    "jest": "^27.0.6",
    "jest-config": "^27.0.6",
    "markdown-to-html": "0.0.13",
    "material-design-lite": "^1.3.0",
    "mini-css-extract-plugin": "^1.4.1",
    "nodemon": "^2.0.7",
    "normalize.css": "^8.0.1",
    "postcss": "^8.2.9",
    "postcss-import": "^14.0.1",
    "postcss-loader": "^5.2.0",
    "precss": "^4.0.0",
    "pretty-quick": "^3.1.1",
    "prop-types": "^15.7.2",
    "randomcolor": "^0.6.2",
    "react": "^17.0.2",
    "react-dev-utils": "^11.0.4",
    "react-dom": "^17.0.2",
    "react-hot-loader": "^4.13.0",
    "react-modal": "^3.12.1",
    "sass": "^1.32.8",
    "sass-loader": "^11.0.1",
    "style-loader": "^2.0.0",
    "stylelint": "^13.12.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-standard": "^21.0.0",
    "stylelint-prettier": "^1.2.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.31.0",
    "webpack-cli": "^4.6.0",
    "webpack-dev-middleware": "^4.1.0",
    "webpack-dev-server": "^3.11.2",
    "webpack-hot-middleware": "^2.25.0",
    "webrtc-adapter": "^7.7.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn run pre-commit",
      "pre-push": "yarn test"
    }
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.3",
    "utf-8-validate": "^5.0.4"
  },
  "resolutions": {
    "@touchto/dev-config": "1.0.4",
    "@touchto/eslint-config": "1.2.4"
  },
  "packageManager": "yarn@3.1.1"
}
